## This is an example of a .env.local file for the Outstatic documentation website
## You can copy this file and rename it to .env.local and fill in the required environment variables

# REQUIRED Environment variables
# OUTSTATIC_API_KEY=YOUR_OUTSTATIC_API_KEY (generate one at Outstatic.com)
# or
# OST_GITHUB_ID=YOUR_GITHUB_OAUTH_ID
# OST_GITHUB_SECRET=YOUR_GITHUB_OAUTH_SECRET

OST_REPO_OWNER=avitorio
OST_REPO_SLUG=outstatic
OST_REPO_BRANCH=BRANCH_OR_PR
OST_MONOREPO_PATH=apps/docs
OST_BASE_PATH=/docs

# OPTIONAL Environment variables

# OPENAI_API_KEY=YOUR_OPEN_AI_API_KEY
# or
# AI_GATEWAY_API_KEY (if using Vercel's AI Gateway)

# Umami Analytics (optional)
# Reuse the outstatic.com website ID to track proxied /docs visits in the same Umami site.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
# NEXT_PUBLIC_UMAMI_DOMAINS=outstatic.com
# NEXT_PUBLIC_UMAMI_HOST_URL=https://outstatic.com

# For more information visit: https://outstatic.com/docs/environment-variables
